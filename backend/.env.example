# ─── Smeta App Backend Environment Variables ───
# Copy this file to .env and fill in the values

# Database URL (default: SQLite in current directory)
DATABASE_URL=sqlite:///./smeta.db

# JWT signing secret — CHANGE THIS in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET=your-secret-key-here

# Admin account credentials (created on first start)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI provider settings (can also be configured via admin panel)
# AI_BASE_URL=https://api.vsegpt.ru/v1
# AI_API_KEY=
# AI_MODEL=
